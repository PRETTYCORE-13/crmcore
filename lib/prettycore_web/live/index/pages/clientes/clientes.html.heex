              <input type="checkbox" checked={@visible_columns["ctecli_ctlsanitario"]} phx-click="toggle_column" phx-value-column="ctecli_ctlsanitario" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
