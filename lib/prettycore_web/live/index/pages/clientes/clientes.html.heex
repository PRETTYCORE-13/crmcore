              <input type="checkbox" checked={@visible_columns["ctecli_aplicacanje"]} phx-click="toggle_column" phx-value-column="ctecli_aplicacanje" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Aplica Canje</span>
            </label>

            <!-- Aplica Devolución -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_aplicadev"]} phx-click="toggle_column" phx-value-column="ctecli_aplicadev" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Aplica Devolución</span>
            </label>

            <!-- Desglosa Kit -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_desglosakit"]} phx-click="toggle_column" phx-value-column="ctecli_desglosakit" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Desglosa Kit</span>
            </label>

            <!-- Factura Grupo -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_facgrupo"]} phx-click="toggle_column" phx-value-column="ctecli_facgrupo" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Factura Grupo</span>
            </label>

            <!-- Tipo Factura Descripción -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_tipofacdes"]} phx-click="toggle_column" phx-value-column="ctecli_tipofacdes" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Tipo Factura Descripción</span>
            </label>

            <!-- Tipo Pago Cliente -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_tipopago"]} phx-click="toggle_column" phx-value-column="ctecli_tipopago" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Tipo Pago Cliente</span>
            </label>

            <!-- SEPARADOR: Metadatos del Sistema -->
            <div class="mt-4 mb-2 pt-3 border-t-2 border-slate-700">
              <label class="text-[11px] uppercase tracking-wider text-red-400 font-semibold">Metadatos del Sistema</label>
            </div>

            <!-- Estado Máquina -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_maqedo"]} phx-click="toggle_column" phx-value-column="s_maqedo" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Estado Máquina</span>
            </label>

            <!-- Fecha Sistema -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_fecha"]} phx-click="toggle_column" phx-value-column="s_fecha" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Fecha Sistema</span>
            </label>

            <!-- Fecha Inserción -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_fi"]} phx-click="toggle_column" phx-value-column="s_fi" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Fecha Inserción</span>
            </label>

            <!-- GUID -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_guid"]} phx-click="toggle_column" phx-value-column="s_guid" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">GUID</span>
            </label>

            <!-- GUID Log -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_guidlog"]} phx-click="toggle_column" phx-value-column="s_guidlog" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">GUID Log</span>
            </label>

            <!-- Usuario -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_usuario"]} phx-click="toggle_column" phx-value-column="s_usuario" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Usuario</span>
            </label>

            <!-- Usuario DB -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_usuariodb"]} phx-click="toggle_column" phx-value-column="s_usuariodb" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Usuario DB</span>
            </label>

            <!-- GUID Notificación -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["s_guidnot"]} phx-click="toggle_column" phx-value-column="s_guidnot" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">GUID Notificación</span>
            </label>

            <!-- Dirección Adicional -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["facadd_codigo_k"]} phx-click="toggle_column" phx-value-column="facadd_codigo_k" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Dirección Adicional</span>
            </label>

            <!-- Receptor FE -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_fereceptor"]} phx-click="toggle_column" phx-value-column="ctecli_fereceptor" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Receptor FE</span>
            </label>

            <!-- Portafolio -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctepor_codigo_k"]} phx-click="toggle_column" phx-value-column="ctepor_codigo_k" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Portafolio</span>
            </label>

            <!-- Tipo Factura Recurrente -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_tipodefacr"]} phx-click="toggle_column" phx-value-column="ctecli_tipodefacr" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Tipo Factura Recurrente</span>
            </label>

            <!-- Concepto Dimensión -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["condim_codigo_k"]} phx-click="toggle_column" phx-value-column="condim_codigo_k" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Concepto Dimensión</span>
            </label>

            <!-- CXC Liquidación -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["ctecli_cxcliq"]} phx-click="toggle_column" phx-value-column="ctecli_cxcliq" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">CXC Liquidación</span>
            </label>

            <!-- Factura Comercial -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["faccom_codigo_k"]} phx-click="toggle_column" phx-value-column="faccom_codigo_k" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Factura Comercial</span>
            </label>

            <!-- Factura Adicional Servicio -->
            <label class="flex items-center gap-3 px-3 py-2.5 bg-slate-900 border border-slate-800 rounded-lg cursor-pointer hover:bg-slate-800 hover:border-slate-600 transition-all select-none">
              <input type="checkbox" checked={@visible_columns["facads_codigo_k"]} phx-click="toggle_column" phx-value-column="facads_codigo_k" class="w-[18px] h-[18px] cursor-pointer accent-gray-800 border-2 border-gray-400 rounded transition-all focus:outline-2 focus:outline-gray-800 focus:outline-offset-2" />
              <span class="flex-1 text-[15px] text-slate-300">Factura Adicional Servicio</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Mensaje de error si existe -->
      <%= if @error do %>
        <div class="bg-red-100 border border-red-300 text-red-800 px-4 py-3 rounded-lg mb-5">
          <strong>⚠ Error:</strong> <%= @error %>
        </div>
      <% end %>

      <!-- LISTA DE CLIENTES CON CARDS EXPANDIBLES (sin espacios) -->
      <div class="rounded-2xl bg-white/95 border border-white/95 shadow-2xl shadow-white/80 overflow-hidden">
        <%= if @loading do %>
          <div class="p-12 text-center">
            <div class="flex flex-col items-center gap-3">
              <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-gray-800"></div>
              <span class="font-medium text-gray-600">Cargando clientes...</span>
            </div>
          </div>
        <% else %>
          <%= if Enum.empty?(@clientes) do %>
            <div class="py-10 px-6 text-center grid place-items-center gap-2.5">
              <div class="w-10 h-10 rounded-full inline-flex items-center justify-center text-2xl bg-slate-900 border border-dashed border-slate-400/50">
                👥
              </div>
              <h2 class="text-base font-medium text-gray-900">Sin clientes registrados</h2>
              <p class="text-sm text-gray-500">No hay clientes para el filtro seleccionado.</p>
            </div>
          <% else %>
            <!-- Contenedor scrolleable horizontal -->
            <div class="overflow-x-auto">
              <div class="min-w-max">
                <!-- ENCABEZADOS DE COLUMNAS -->
                <div class="flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-slate-900 to-slate-800 border-b-2 border-slate-700">
                  <!-- Acciones Header -->
                  <div class="w-24 flex-shrink-0">
                    <span class="text-xs font-bold text-slate-300 uppercase tracking-wide">Acciones</span>
                  </div>

                  <!-- UDN Header -->
                  <%= if @visible_columns["udn"] do %>
                    <div class="w-16 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">UDN</span>
                    </div>
                  <% end %>

                  <!-- Código Header -->
                  <%= if @visible_columns["codigo"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Código</span>
                    </div>
                  <% end %>

                  <!-- Dir Header -->
                  <%= if @visible_columns["ctedir_codigo_k"] do %>
                    <div class="w-16 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Dir</span>
                    </div>
                  <% end %>

                  <!-- Nombre Header -->
                  <%= if @visible_columns["razon_social"] do %>
                    <div class="flex-1 min-w-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Nombre</span>
                    </div>
                  <% end %>

                                    <!-- Nombre Comercial -->
                  <%= if @visible_columns["nombre_comercial"] do %>
                    <div class="w-36 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">nombre_comercial</span>
                    </div>
                  <% end %>

                  <!-- RFC Header -->
                  <%= if @visible_columns["rfc"] do %>
                    <div class="w-32 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">RFC</span>
                    </div>
                  <% end %>

                  <!-- Preventa Header -->
                  <%= if @visible_columns["preventa"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Preventa</span>
                    </div>
                  <% end %>

                  <!-- Entrega Header -->
                  <%= if @visible_columns["entrega"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Entrega</span>
                    </div>
                  <% end %>

                  <!-- Autoventa Header -->
                  <%= if @visible_columns["autoventa"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Autoventa</span>
                    </div>
                  <% end %>


                  <!-- MAP X -->
                  <%= if @visible_columns["map_x"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">map_x</span>
                    </div>
                  <% end %>

                  <!-- MAP Y -->
                  <%= if @visible_columns["map_y"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">map_y</span>
                    </div>
                  <% end %>



                                    <!-- Chevron Header (vacío) -->
                  <div class="flex-shrink-0">
                    <span class="w-5 h-5 inline-block"></span>
                  </div>


                  <!-- Estatus Header -->
                  <%= if @visible_columns["estatus"] do %>
                    <div class="w-28 flex-shrink-0">
                      <span class="text-xs font-bold text-slate-200 uppercase tracking-wide">Estatus</span>
                    </div>
                  <% end %>



                </div>

    <!-- REGISTROS COMPACTOS SIN ESPACIOS -->
<%= for cliente <- @clientes do %>
  <% is_expanded = client_expanded?(@expanded_clients, cliente.codigo, cliente.ctedir_codigo_k) %>
  <% avatar_bg = avatar_color(cliente.codigo) %>

  <div class="border-b border-gray-200 last:border-b-0">
    <!-- VISTA COMPACTA: Una sola línea clickeable -->
    <div
      class="flex items-center gap-3 px-4 py-2.5 hover:bg-gradient-to-r hover:from-gray-50/50 hover:to-transparent cursor-pointer transition-all duration-200"
      phx-click="toggle_client_details"
      phx-value-codigo={cliente.codigo}
      phx-value-dir={cliente.ctedir_codigo_k}
    >
      <!-- BOTONES DE ACCIÓN -->
      <div class="w-24 flex-shrink-0 flex items-center gap-1.5">
        <button
          phx-click="edit_cliente"
          phx-value-codigo={cliente.codigo}
          phx-value-dir={cliente.ctedir_codigo_k}
          class="w-8 h-8 flex items-center justify-center rounded-full transition-all duration-200 group hover:shadow-lg hover:scale-105 bg-purple-600 hover:bg-purple-700"
          title="Editar cliente"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </button>
        <button
          phx-click="open_stats_modal"
          phx-value-codigo={cliente.codigo}
          phx-value-dir={cliente.ctedir_codigo_k || "1"}
          class="w-8 h-8 flex items-center justify-center rounded-full transition-all duration-200 group hover:shadow-lg hover:scale-105 bg-teal-500 hover:bg-teal-600"
          title="Estadísticas"
        >
          <svg class="h-4 w-4 text-white group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" />
          </svg>
        </button>
        <!-- Badge clasificación (desde CTE_CLIENTES, actualizado por estadísticas) -->
        <% clasif_val = Map.get(@stats_clasificaciones, cliente.codigo) || cliente.clasificacion %>
        <%= if clasif_val && clasif_val != "SIN RANGO" do %>
          <% clasif = String.upcase(clasif_val) %>
          <img src={clasificacion_imagen(clasif)} alt={clasif} title={"Clasificación: #{clasif}"} class="h-10" />
        <% end %>
      </div>

                  <!-- UDN -->
                  <%= if @visible_columns["udn"] do %>
                    <div class="w-16 flex-shrink-0">
                      <span class="px-2 py-0.5 bg-gray-200 text-gray-800 rounded text-xs font-semibold">
                        <%= cliente.udn %>
                      </span>
                    </div>
                  <% end %>

                  <!-- CÓDIGO -->
                  <%= if @visible_columns["codigo"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-sm font-bold text-gray-900"><%= cliente.codigo %></span>
                    </div>
                  <% end %>

                  <!-- DIR -->
                  <%= if @visible_columns["ctedir_codigo_k"] do %>
                    <div class="w-16 flex-shrink-0">
                      <span class="text-xs text-gray-600"><%= cliente.ctedir_codigo_k %></span>
                    </div>
                  <% end %>

                  <!-- NOMBRE -->
                  <%= if @visible_columns["razon_social"] do %>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-gray-900 truncate block" title={cliente.razon_social}>
                        <%= cliente.razon_social %>
                      </span>
                    </div>
                  <% end %>

                                    <!-- NOMBRE COMERCIAL -->
                  <%= if @visible_columns["nombre_comercial"] do %>
                    <div class="w-36 flex-shrink-0">
                      <span class="text-xs text-gray-700 truncate block" title={cliente.nombre_comercial}>
                        <%= cliente.nombre_comercial || "—" %>
                      </span>
                    </div>
                  <% end %>

                  <!-- RFC -->
                  <%= if @visible_columns["rfc"] do %>
                    <div class="w-32 flex-shrink-0">
                      <span class="text-xs font-mono text-gray-700"><%= cliente.rfc %></span>
                    </div>
                  <% end %>

                  <!-- PREVENTA -->
                  <%= if @visible_columns["preventa"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="px-1.5 py-0.5 bg-gray-200 text-gray-800 rounded text-xs font-medium">
                        <%= cliente.preventa %>
                      </span>
                    </div>
                  <% end %>

                  <!-- ENTREGA -->
                  <%= if @visible_columns["entrega"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="px-1.5 py-0.5 bg-emerald-100 text-emerald-700 rounded text-xs font-medium">
                        <%= cliente.entrega %>
                      </span>
                    </div>
                  <% end %>

                  <!-- AUTOVENTA -->
                  <%= if @visible_columns["autoventa"] do %>
                    <div class="w-20 flex-shrink-0">
                      <%= if cliente.autoventa do %>
                        <span class="px-1.5 py-0.5 bg-orange-100 text-orange-700 rounded text-xs font-medium">
                          <%= cliente.autoventa %>
                        </span>
                      <% else %>
                        <span class="text-xs text-gray-400">—</span>
                      <% end %>
                    </div>
                  <% end %>

                  <!-- MAP X -->
                  <%= if @visible_columns["map_x"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs text-gray-700"><%= cliente.map_x || "—" %></span>
                    </div>
                  <% end %>

                  <!-- MAP Y -->
                  <%= if @visible_columns["map_y"] do %>
                    <div class="w-20 flex-shrink-0">
                      <span class="text-xs text-gray-700"><%= cliente.map_y || "—" %></span>
                    </div>
                  <% end %>



                  <!-- ESTADO -->
                  <%= if @visible_columns["estatus"] do %>
                    <div class="w-28 flex-shrink-0">
                      <span class={estatus_badge_class(cliente.estatus)}>
                        <%= estatus_label(cliente.estatus) %>
                      </span>
                    </div>
                  <% end %>

                  <!-- CHEVRON -->
                  <div class="flex-shrink-0">
                    <svg
                      class={[
                        "w-5 h-5 text-gray-400 transition-transform duration-300",
                        if(is_expanded, do: "rotate-180", else: "rotate-0")
                      ]}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </div>
                </div>

                <!-- VISTA EXPANDIDA -->
                <div class={[
                  "transition-all duration-300 ease-in-out overflow-hidden bg-gradient-to-r from-slate-50 to-gray-50/30",
                  if(is_expanded, do: "max-h-96 opacity-100", else: "max-h-0 opacity-0")
                ]}>
                  <div class="px-4 py-4 space-y-3">

                    <!-- SECCIÓN FINANCIERO -->
                    <div class="flex items-center gap-2 text-sm">
                      <span class="text-lg">💳</span>
                      <span class="font-semibold text-gray-700">Financiero:</span>
                      <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-gray-800">
                          Días Crédito: <span class="font-bold text-gray-800"><%= cliente.diascredito %>d</span>
                        </span>
                        <span class="text-gray-400">|</span>
                        <span class="text-gray-800">
                          Límite: <span class="font-bold text-emerald-600">$<%= cond do
                            is_nil(cliente.limite_credito) -> "0.00"
                            is_struct(cliente.limite_credito, Decimal) -> :erlang.float_to_binary(Decimal.to_float(cliente.limite_credito), decimals: 2)
                            is_float(cliente.limite_credito) -> :erlang.float_to_binary(cliente.limite_credito, decimals: 2)
                            is_integer(cliente.limite_credito) -> :erlang.float_to_binary(cliente.limite_credito / 1, decimals: 2)
                            true -> to_string(cliente.limite_credito)
                          end %></span>
                        </span>
                        <span class="text-gray-400">|</span>
                        <span class="text-gray-800">
                          Lista: <span class="font-bold text-gray-800"><%= cliente.paquete_codigo %></span>
                        </span>
                        <span class="text-gray-400">|</span>
                        <span class="text-gray-800">
                          Frecuencia: <span class="font-bold text-gray-700"><%= cliente.frecuencia_codigo %></span>
                        </span>
                      </div>
                    </div>

                    <!-- SECCIÓN CONTACTO -->
                    <div class="flex items-center gap-2 text-sm">
                      <span class="text-lg">📧</span>
                      <span class="font-semibold text-gray-700">Contacto:</span>
                      <div class="flex items-center gap-3 flex-wrap">
                        <%= if cliente.email_receptor do %>
                          <a href={"mailto:#{cliente.email_receptor}"} class="text-gray-800 hover:underline font-medium">
                            <%= cliente.email_receptor %>
                          </a>
                        <% else %>
                          <span class="text-amber-600 font-medium">Sin email</span>
                        <% end %>
                        <span class="text-gray-400">|</span>
                        <span class="text-gray-800">
                          Forma Pago: <span class="font-bold"><%= cliente.forma_pago %></span>
                        </span>
                        <span class="text-gray-400">|</span>
                        <span class="text-gray-800">
                          Método Pago: <span class="font-bold"><%= cliente.metodo_pago %></span>
                        </span>
                      </div>
                    </div>

                    <!-- BOTONES DE ACCIÓN -->
                    <div class="flex gap-2 pt-2">
                      <button
                        type="button"
                        phx-click="edit_client"
                        phx-value-client-id={cliente.codigo}
                        class="px-3 py-1.5 bg-purple-600 hover:bg-purple-700 text-white text-xs font-semibold rounded transition-colors"
                      >
                        ✏️ Editar
                      </button>
                      <%= if cliente.email_receptor do %>
                        <button
                          type="button"
                          phx-click="send_email"
                          phx-value-email={cliente.email_receptor}
                          class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded transition-colors"
                        >
                          📧 Email
                        </button>
                      <% end %>
                    </div>
                    </div>
                  </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Paginación personalizada (igual que workorder) -->
      <%= if Map.get(@meta, :total_pages, 0) > 1 do %>
          <div class="flex items-center justify-center gap-2 mt-6 flex-wrap">
            <!-- Botón Anterior -->
            <%= if Map.get(@meta, :has_previous_page?, false) do %>
              <a
                href={build_pagination_path(%{"page" => Map.get(@meta, :previous_page, 1)}, @params)}
                class="px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-gray-800 to-black rounded-lg hover:from-gray-700 hover:to-gray-900 transition-all shadow-sm hover:shadow-md"
              >
                Anterior
              </a>
            <% else %>
              <span class="px-4 py-2 text-sm font-medium text-gray-400 bg-gray-200 rounded-lg cursor-not-allowed">Anterior</span>
            <% end %>

            <!-- Números de página visibles (solo 3) -->
            <div class="flex items-center gap-1">
              <%= for page <- get_visible_pages(Map.get(@meta, :current_page, 1), Map.get(@meta, :total_pages, 1), 3) do %>
                <%= if page == Map.get(@meta, :current_page, 1) do %>
                  <span class="min-w-[40px] h-10 flex items-center justify-center text-sm font-semibold bg-gradient-to-r from-gray-800 to-black text-white rounded-lg shadow-md">
                    <%= page %>
                  </span>
                <% else %>
                  <a
                    href={build_pagination_path(%{"page" => page}, @params)}
                    class="min-w-[40px] h-10 flex items-center justify-center text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 hover:text-gray-800 transition-all"
                  >
                    <%= page %>
                  </a>
                <% end %>
              <% end %>
            </div>

            <!-- Botón Siguiente -->
            <%= if Map.get(@meta, :has_next_page?, false) do %>
              <a
                href={build_pagination_path(%{"page" => Map.get(@meta, :next_page, 1)}, @params)}
                class="px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-gray-800 to-black rounded-lg hover:from-gray-700 hover:to-gray-900 transition-all shadow-sm hover:shadow-md"
              >
                Siguiente
              </a>
            <% else %>
              <span class="px-4 py-2 text-sm font-medium text-gray-400 bg-gray-200 rounded-lg cursor-not-allowed">Siguiente</span>
            <% end %>
          </div>
      <% end %>
    </section>

    <!-- Modal de Estadísticas -->
    <%= if @stats_modal_open do %>
      <div
        class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
      >
        <div
          class="bg-gray-50 rounded-2xl shadow-2xl w-full max-w-3xl mx-4 overflow-hidden max-h-[90vh] overflow-y-auto"
          phx-click-away="close_stats_modal"
        >
          <!-- Header -->
          <div class="bg-gradient-to-r from-gray-800 via-gray-900 to-black px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" />
                </svg>
              </div>
              <div>
                <h2 class="text-white text-lg font-semibold">Dashboard — Cliente <%= @stats_modal_ref %></h2>
                <p class="text-white/60 text-xs">Resumen de indicadores clave</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <!-- Badge de clasificación (desde CTE_CLIENTES, no Estadísticas) -->
              <%= if @stats_modal_clasificacion && @stats_modal_clasificacion != "SIN RANGO" do %>
                <% clasif = String.upcase(@stats_modal_clasificacion) %>
                <img src={clasificacion_imagen(clasif)} alt={clasif} title={"Clasificación: #{clasif}"} class="h-12" />
              <% end %>
              <button
                phx-click="close_stats_modal"
                class="text-white/60 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Body: Dashboard -->
          <div class="p-4 sm:p-6 space-y-4">

            <%= if @stats_loading do %>
              <div class="flex items-center justify-center py-12">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gray-800"></div>
                <span class="ml-3 text-sm text-gray-500">Cargando estadísticas...</span>
              </div>
            <% else %>

            <!-- Fila 1: Venta Anual + Cartera -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

              <!-- VENTA ANUAL -->
              <% total_venta = if @stats_data, do: @stats_data.total_venta_anual, else: 0.0 %>
              <% venta_meses = if @stats_data, do: @stats_data.venta_anual, else: [] %>
              <% max_venta_mes = if venta_meses != [], do: Enum.max_by(venta_meses, fn v -> v["Venta"] || 0 end)["Venta"] || 1, else: 1 %>
              <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" />
                      </svg>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-700">Venta Anual</h3>
                  </div>
                  <span class="text-xs text-emerald-600 font-medium bg-emerald-50 px-2 py-0.5 rounded-full"><%= length(venta_meses) %> meses</span>
                </div>
                <p class="text-2xl font-bold text-gray-900 mb-1">$<%= format_number(total_venta) %></p>
                <p class="text-xs text-gray-500"><%= if total_venta > 0, do: "#{length(venta_meses)} meses con actividad", else: "Sin datos disponibles" %></p>
                <!-- Mini barras visuales -->
                <%= if venta_meses != [] do %>
                  <div class="mt-3 flex items-end gap-1 h-10">
                    <%= for mes <- venta_meses do %>
                      <% pct = if max_venta_mes > 0, do: (mes["Venta"] || 0) / max_venta_mes * 100, else: 0 %>
                      <div class="flex-1 bg-emerald-400 rounded-t" style={"height: #{max(pct, 5)}%"}></div>
                    <% end %>
                  </div>
                  <div class="flex justify-between mt-1">
                    <span class="text-[9px] text-gray-400"><%= if List.first(venta_meses), do: String.slice(List.first(venta_meses)["mes"] || "", 0, 7), else: "" %></span>
                    <span class="text-[9px] text-gray-400"><%= if List.last(venta_meses), do: String.slice(List.last(venta_meses)["mes"] || "", 0, 7), else: "" %></span>
                  </div>
                <% end %>
              </div>

              <!-- CARTERA -->
              <% vigente = if @stats_data, do: @stats_data.cartera_vigente, else: 0.0 %>
              <% vencida = if @stats_data, do: @stats_data.cartera_vencida, else: 0.0 %>
              <% total_cartera = vigente + vencida %>
              <% pct_vigente = if total_cartera > 0, do: vigente / total_cartera * 100, else: 0 %>
              <% pct_vencida = if total_cartera > 0, do: vencida / total_cartera * 100, else: 0 %>
              <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" />
                      </svg>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-700">Cartera</h3>
                  </div>
                  <span class="text-xs text-amber-600 font-medium bg-amber-50 px-2 py-0.5 rounded-full">Saldo</span>
                </div>
                <p class="text-2xl font-bold text-gray-900 mb-1">$<%= format_number(total_cartera) %></p>
                <p class="text-xs text-gray-500"><%= if total_cartera > 0, do: "Saldo pendiente", else: "Sin adeudos registrados" %></p>
                <!-- Indicadores de cartera -->
                <div class="mt-3 space-y-2">
                  <div>
                    <div class="flex justify-between text-xs mb-1">
                      <span class="text-gray-500">Vigente</span>
                      <span class="font-medium text-green-600">$<%= format_number(vigente) %></span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                      <div class="bg-green-400 h-2 rounded-full" style={"width: #{pct_vigente}%"}></div>
                    </div>
                  </div>
                  <div>
                    <div class="flex justify-between text-xs mb-1">
                      <span class="text-gray-500">Vencida</span>
                      <span class="font-medium text-red-500">$<%= format_number(vencida) %></span>
                    </div>
                    <div class="w-full bg-gray-100 rounded-full h-2">
                      <div class="bg-red-400 h-2 rounded-full" style={"width: #{pct_vencida}%"}></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Fila 2: Coolers + Ultima Venta -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

              <!-- COOLERS -->
              <% enfriadores = if @stats_data, do: @stats_data.enfriadores, else: 0 %>
              <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-sky-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="2" width="16" height="20" rx="2" /><line x1="4" y1="10" x2="20" y2="10" /><line x1="10" y1="2" x2="10" y2="10" />
                      </svg>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-700">Enfriadores</h3>
                  </div>
                  <span class="text-xs text-sky-600 font-medium bg-sky-50 px-2 py-0.5 rounded-full">Equipos</span>
                </div>
                <div class="flex items-baseline gap-2 mb-1">
                  <p class="text-2xl font-bold text-gray-900"><%= enfriadores %></p>
                  <p class="text-sm text-gray-500">unidades</p>
                </div>
                <p class="text-xs text-gray-500"><%= if enfriadores > 0, do: "Equipos asignados", else: "Sin equipos asignados" %></p>
              </div>

              <!-- ULTIMA VENTA (pedido) -->
              <% pedido = if @stats_data, do: @stats_data.pedido, else: nil %>
              <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
                      </svg>
                    </div>
                    <h3 class="text-sm font-semibold text-gray-700">Ultimo Pedido</h3>
                  </div>
                  <span class="text-xs text-purple-600 font-medium bg-purple-50 px-2 py-0.5 rounded-full">Reciente</span>
                </div>
                <%= if pedido do %>
                  <p class="text-2xl font-bold text-gray-900 mb-1">$<%= format_number(pedido["Valor"] || 0) %></p>
                  <p class="text-xs text-gray-500"><%= pedido["REFERENCIA"] %></p>
                  <div class="mt-3 bg-gray-50 rounded-lg p-3 space-y-2">
                    <div class="flex justify-between text-xs">
                      <span class="text-gray-500">Fecha</span>
                      <span class="font-medium text-gray-700"><%= String.slice(pedido["LIQUID_FECHAENT"] || "---", 0, 10) %></span>
                    </div>
                    <div class="flex justify-between text-xs">
                      <span class="text-gray-500">Referencia</span>
                      <span class="font-medium text-gray-700"><%= pedido["REFERENCIA"] || "---" %></span>
                    </div>
                    <div class="flex justify-between text-xs">
                      <span class="text-gray-500">Productos</span>
                      <span class="font-medium text-gray-700"><%= pedido["PRODUCTOS"] || 0 %></span>
                    </div>
                    <div class="flex justify-between text-xs">
                      <span class="text-gray-500">Cajas</span>
                      <span class="font-medium text-gray-700"><%= format_number(pedido["Cajas"] || 0) %></span>
                    </div>
                    <div class="flex justify-between text-xs">
                      <span class="text-gray-500">Descuento</span>
                      <span class="font-medium text-gray-700">$<%= format_number(pedido["Descuento"] || 0) %></span>
                    </div>
                  </div>
                <% else %>
                  <p class="text-2xl font-bold text-gray-900 mb-1">---</p>
                  <p class="text-xs text-gray-500">Sin pedidos registrados</p>
                <% end %>
              </div>
            </div>

            <% end %>
          </div>
        </div>
      </div>
    <% end %>








